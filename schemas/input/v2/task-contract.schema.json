{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ados.internal/schemas/input/v2/task-contract.schema.json",
  "title": "ADOS task contract ingestion record",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": ["string", "number"] },
    "taskId": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "status": { "type": "string" },
    "mission": { "type": "string" },
    "objective": { "type": "string" },
    "assignedAgent": { "type": "string" },
    "ownerApprovalRef": { "type": "string" }
  },
  "anyOf": [{ "required": ["taskId"] }, { "required": ["id"] }],
  "additionalProperties": true
}
