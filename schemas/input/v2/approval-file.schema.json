{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ados.internal/schemas/input/v2/approval-file.schema.json",
  "title": "ADOS approval request file ingestion record",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": ["string", "number"] },
    "approvalId": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "action": { "type": "string" },
    "status": { "type": "string" }
  },
  "anyOf": [{ "required": ["approvalId"] }, { "required": ["id"] }],
  "additionalProperties": true
}
