{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ados.local/schemas/task-node.schema.json",
  "title": "TaskNode",
  "type": "object",
  "additionalProperties": true,
  "required": ["taskId", "objective", "status", "owner", "reviewer", "authority"],
  "properties": {
    "taskId": { "type": "string" },
    "objective": { "type": "string" },
    "status": { "type": "string" },
    "owner": { "type": "string" },
    "reviewer": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "allowedPaths": { "type": "array", "items": { "type": "string" } },
    "prohibitedPaths": { "type": "array", "items": { "type": "string" } },
    "worktree": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "commit": { "type": ["string", "null"] },
    "leaseId": { "type": ["string", "null"] },
    "requiredGates": { "type": "array", "items": { "type": "string" } },
    "evidencePaths": { "type": "array", "items": { "type": "string" } },
    "blockerClass": { "type": ["string", "null"] },
    "authority": { "enum": ["AUTHORITATIVE", "NON_AUTHORITATIVE", "OBSERVED"] }
  }
}
